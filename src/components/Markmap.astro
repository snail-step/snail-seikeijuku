---
// 用法：在 .mdx 中傳入 markdown 大綱字串，會渲染成可互動的心智圖。
// <Markmap markdown={`- 根節點\n  - 子節點`} />
interface Props {
  markdown: string;
  /** 圖的高度（CSS 值），預設 560px */
  height?: string;
  /** 背景色（CSS 值），預設沿用站台背景色 */
  background?: string;
  /** 節點文字顏色（CSS 值），預設淺色模式深灰、深色模式淺灰（跟隨站台主題） */
  textColor?: string;
}
const {
  markdown,
  height = "560px",
  background = "var(--sl-color-bg)",
  textColor = "var(--sl-color-gray-2)",
} = Astro.props;
---

<div
  class="markmap-wrapper"
  style={`height:${height}; background:${background}; --markmap-text-color:${textColor};`}
>
  <svg class="markmap" data-markdown={markdown}></svg>
</div>

<style>
  .markmap-wrapper {
    width: 100%;
    margin: 1.5rem 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .markmap {
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import { Transformer } from "markmap-lib";
  import { Markmap } from "markmap-view";

  const transformer = new Transformer();

  function render() {
    document.querySelectorAll<SVGElement>("svg.markmap").forEach((svg) => {
      if (svg.dataset.rendered) return;
      const md = svg.getAttribute("data-markdown") ?? "";
      const { root } = transformer.transform(md);
      Markmap.create(
        svg,
        {
          autoFit: true,
          duration: 400,
          // markmap 預設會在 SVG 內注入固定的 --markmap-text-color: #333，
          // 蓋掉外層 wrapper 設定的顏色。這裡用「自我參照」讓該變數失效，
          // 強制改用繼承自 .markmap-wrapper 的值（會隨站台明暗主題切換）。
          style: () => ".markmap{--markmap-text-color:var(--markmap-text-color);}",
        },
        root,
      );
      svg.dataset.rendered = "true";
    });
  }

  render();
  // Starlight 使用 view transitions，換頁後重新渲染
  document.addEventListener("astro:page-load", render);
</script>
