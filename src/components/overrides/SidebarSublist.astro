---
import type { StarlightRouteData } from '@astrojs/starlight/route-data';

interface Props {
    sublist: StarlightRouteData['sidebar'];
    nested?: boolean;
}

const { sublist } = Astro.props;
---

{
    sublist.map((entry) =>
        entry.type === 'link' ? (
            <a
                href={entry.href}
                aria-current={entry.isCurrent && 'page'}
                class:list={['entry-link', entry.attrs.class]}
                {...entry.attrs}
            >
                <span class="entry-link-inner">
                    {entry.label}
                    {entry.badge && <span class="entry-badge">{entry.badge.text}</span>}
                </span>
            </a>
        ) : (
            <details class="container-sidebar-entry" open={!entry.collapsed}>
                <summary class="entry-title">
                    {entry.label}
                    <svg class="entry-caret" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 6l6 6-6 6" />
                    </svg>
                </summary>
                <div class="container-group-link">
                    <Astro.self sublist={entry.entries} nested />
                </div>
            </details>
        )
    )
}

<style>
    .container-sidebar-entry {
        gap: 0.25rem;
        flex-direction: column;
        display: flex;
    }

    .entry-title {
        font-weight: 600;
        font-size: 0.75rem;
        line-height: 1rem;
        padding-top: calc(var(--spacing) * 1);
        padding-bottom: calc(var(--spacing) * 1);
        padding-left: calc(var(--spacing) * 2);
        padding-right: calc(var(--spacing) * 2);
        border-radius: calc(var(--radius) - 2px);
        color: var(--gray-2);
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        list-style: none;
        user-select: none;
        background-color: rgba(184, 184, 184, 0.3);
        margin-top: calc(var(--spacing) * 2);
    }

    .entry-title::-webkit-details-marker {
        display: none;
    }

    .entry-caret {
        flex-shrink: 0;
        transition: transform 0.15s;
    }

    .container-sidebar-entry[open] > .entry-title .entry-caret {
        transform: rotate(90deg);
    }

    .container-group-link {
        font-size: 0.875rem;
        line-height: 1.25rem;
        gap: 2px;
        grid-auto-rows: max-content;
        grid-auto-flow: row;
        display: grid;
    }

    .entry-link {
        color: var(--foreground);
        font-weight: 400;
        align-items: center;
        width: 100%;
        height: 1.875rem;
        display: flex;
        text-decoration: none;
        font-size: 0.8rem;
        line-height: 1.125rem;
    }

    .entry-link-inner {
        display: flex;
        align-items: center;
        padding-left: calc(var(--spacing) * 2);
        padding-right: calc(var(--spacing) * 2);
        border-radius: calc(var(--radius) - 2px);
        height: 100%;
        transition:
            color 0.15s,
            background-color 0.15s;
    }

    .entry-link[aria-current='page'] {
        font-weight: 500;
    }

    .entry-link[aria-current='page'] .entry-link-inner {
        color: #00939d;
        font-weight: 700;
    }

    .entry-link:hover:not([aria-current='page']) .entry-link-inner {
        background-color: rgba(91, 91, 91, 0.25);
        color: var(--secondary-foreground);
    }
    
    .entry-badge {
        color: var(--gray-6);
        line-height: 1;
        font-size: 0.75rem;
        padding-top: calc(var(--spacing) * 0.5);
        padding-bottom: calc(var(--spacing) * 0.5);
        padding-left: calc(var(--spacing) * 1.5);
        padding-right: calc(var(--spacing) * 1.5);
        background-color: rgb(173 250 29);
        border-radius: calc(var(--radius) - 2px);
        margin-left: calc(var(--spacing) * 2);
    }
</style>
