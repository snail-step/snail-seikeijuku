---
// 覆寫 Lucode 的行動版抽屜選單（Drawer）。
// 原版只渲染「有群組標籤」的分類（entry.type !== 'link'），會把最外層攤平、
// 未分組的文章（astro.config 的 sidebar 第一筆 autogenerate）整批濾掉，
// 導致這些文章在手機上不顯示。這裡加上對最外層 link 項目的渲染。
import userConfig from 'virtual:lucode-starlight-config';
import starlightConfig from 'virtual:starlight/user-config';
import { getRelativeLocaleUrl } from 'astro:i18n';
const { sidebar } = Astro.locals.starlightRoute;

const currentPath = Astro.url.pathname;

// 與 Lucode NavBar.astro 的 getTranslation 同邏輯（原版位於套件 parts/，無法跨 exports 匯入，故內聯）。
const defaultLang =
    starlightConfig.defaultLocale?.lang || starlightConfig.defaultLocale?.locale || 'en';

function getTranslation(translations: Record<string, string>) {
    const defaultTranslation = translations[defaultLang];
    if (Astro.currentLocale) {
        return translations[Astro.currentLocale] ?? defaultTranslation;
    }
    return defaultTranslation;
}
---

<div popover="auto" id="drawer">
    <button class="sheet-overlay" popovertarget="drawer" popovertargetaction="hide"></button>
    <div class="content">
        <div class="header">
            <button class="drag-icon" popovertarget="drawer" popovertargetaction="hide">
                <span></span>
            </button>
        </div>
        <div class="body">
            <div class="links-nav">
                {
                    userConfig.navLinks?.map((nav) => {
                        const absoluteLinkRegex = /^https?:\/\//;

                        const link =
                            !absoluteLinkRegex.test(nav.link) && Astro.currentLocale
                                ? getRelativeLocaleUrl(Astro.currentLocale, nav.link)
                                : nav.link;
                        const label =
                            typeof nav.label === 'string'
                                ? nav.label
                                : getTranslation(nav.label);

                        return (
                            <a href={link} {...nav.attrs}>
                                {label}
                                {nav.badge && <span class="badge">{nav.badge}</span>}
                            </a>
                        );
                    })
                }
            </div>

            <div class="links-docs">
                {
                    sidebar.map((entry) =>
                        entry.type === 'link' ? (
                            // 最外層、未分組的文章（攤平顯示）
                            <a
                                href={entry.href}
                                {...entry.attrs}
                                data-active={currentPath === entry.href}
                                class="top-level-link"
                            >
                                {entry.label}
                            </a>
                        ) : (
                            <div class="container-sidebar-entry">
                                <h4 class="entry-title">{entry.label}</h4>

                                {entry.entries.map(
                                    (link) =>
                                        link.type === 'link' && (
                                            <a
                                                href={link.href}
                                                {...link.attrs}
                                                data-active={currentPath === link.href}
                                            >
                                                {link.label}
                                            </a>
                                        )
                                )}
                            </div>
                        )
                    )
                }
            </div>
        </div>
    </div>
</div>

<style>
    button {
        all: unset;
    }

    [popover] {
        padding: 0;
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        display: flex;
        opacity: 0;
        pointer-events: none;
        align-items: center;
        flex-direction: column;
        justify-content: flex-end;
        transition: 0.1s linear;
        z-index: 1000;
        background: transparent;
        border: none;
        overflow: hidden;
    }

    [popover]::backdrop {
        background: color-mix(in oklab, black 80%, transparent);
        backdrop-filter: blur(2px);
    }

    [popover]:popover-open {
        opacity: 1;
        pointer-events: auto;
    }

    [popover]:popover-open .content {
        transform: translateY(0%);
    }

    .sheet-overlay {
        position: fixed;
        top: 0;
        left: 0;
        z-index: -1;
        width: 100vw;
        height: 100vh;
        opacity: 0.1;
        background-color: transparent;
    }

    .content {
        width: 100%;
        position: relative;
        background: var(--background);
        max-height: 100vh;
        height: 70vh;
        max-width: 1150px;
        transform: translateY(100%);
        border-radius: 12px 12px 0 0;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.03);
        transition: 0.3s ease;
    }

    .header {
        display: flex;
        justify-content: center;
    }

    .header .drag-icon span {
        height: calc(var(--spacing) * 1);
        width: 100px;
        display: block;
        background-color: color-mix(in oklab, var(--foreground) 20%, transparent);
        border-radius: 9999px;
        margin-top: calc(var(--spacing) * 1);
    }

    .body {
        height: 100%;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .body::-webkit-scrollbar {
        width: 0;
    }

    .links-nav {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .links-nav a {
        font-size: 1rem;
        line-height: 1.5rem;
        color: inherit;
        text-decoration: inherit;
    }

    .links-docs {
        display: flex;
        flex-direction: column;
        gap: calc(var(--spacing) * 2);
    }

    /* 最外層攤平文章：第一筆給予與分類群組相同的上方間距 */
    .links-docs > .top-level-link:first-child {
        padding-top: calc(var(--spacing) * 6);
    }

    .links-docs > .top-level-link {
        font-size: 1rem;
        line-height: 1.2rem;
        color: var(--muted-foreground);
        text-decoration: inherit;

        &[data-active='true'] {
            color: var(--foreground);
            font-weight: 500;
        }
    }

    .container-sidebar-entry {
        padding-top: calc(var(--spacing) * 6);
        display: flex;
        flex-direction: column;
        gap: calc(var(--spacing) * 2);

        &:last-child {
            margin-bottom: calc(var(--spacing) * 4);
        }
    }

    .entry-title {
        font-weight: 500;
    }

    .container-sidebar-entry a {
        font-size: 1rem;
        line-height: 1.2rem;
        color: var(--muted-foreground);
        text-decoration: inherit;

        &[data-active='true'] {
            color: var(--foreground);
            font-weight: 500;
        }
    }

    .badge {
        padding-top: calc(var(--spacing) * 0.5);
        padding-bottom: calc(var(--spacing) * 0.5);
        padding-left: calc(var(--spacing) * 1.5);
        padding-right: calc(var(--spacing) * 1.5);
        margin-left: calc(var(--spacing) * 2);
        border-radius: 0.375rem;
        font-size: 0.75rem;
        line-height: 1rem;
        font-weight: 400;
        line-height: 1;
        text-decoration: none;
        background: #adfa1d;
        color: #000000;
    }
</style>

<script>
    const drawer = document.getElementById('drawer');
    if (drawer) {
        drawer.addEventListener('toggle', (e) => {
            const event = e as ToggleEvent;
            const isOpen = event.newState === 'open';
            document.documentElement.style.overflow = isOpen ? 'hidden' : '';
            document.body.style.overflow = isOpen ? 'hidden' : '';
        });
    }
</script>
